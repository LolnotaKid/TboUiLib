        selectionBar.Visible = true
        G2L_tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        currentlySelectedTab = G2L_tabButton
    end)

    if not firstTabSelected then
        for _, v in ipairs(G2L_contentContainer:GetChildren()) do
            if v:IsA("ScrollingFrame") then
                v.Visible = false
            end
        end
        G2L_tabFrame.Visible = true
        selectionBar.Visible = true
        G2L_tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        G2L_tabButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        currentlySelectedTab = G2L_tabButton
        firstTabSelected = true
    end

    local Tab = {}
    Tab._frame = G2L_tabFrame
    UiLib._tabs = UiLib._tabs or {}
    table.insert(UiLib._tabs, Tab)

    function Tab:CreateButton(V1)
        local V2 = V1.Name or "Button"
        local V3 = V1.Callback or function() end
        local G2L_button = Instance.new("TextButton", G2L_tabFrame)
        G2L_button.Text = V2
        G2L_button.TextSize = 18
        G2L_button.TextWrapped = true
        G2L_button.TextStrokeTransparency = 0.2
        G2L_button.BorderSizePixel = 0
        G2L_button.BackgroundTransparency = 0
        G2L_button.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        G2L_button.TextColor3 = Color3.fromRGB(255, 255, 255)
        G2L_button.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        G2L_button.FontFace = fontFaceRegular 
        G2L_button.Size = UDim2.new(0.98, 0, 0, 36)
        G2L_button.AutoButtonColor = false

        Instance.new("UICorner", G2L_button).CornerRadius = UDim.new(0, 8)

        G2L_button.MouseEnter:Connect(function()
            G2L_button:TweenSize(UDim2.new(1, 0, 0, 40), "Out", "Quad", 0.15, true)
            G2L_button.BackgroundTransparency = 0
            G2L_button.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        end)
        G2L_button.MouseLeave:Connect(function()
            G2L_button:TweenSize(UDim2.new(0.98, 0, 0, 36), "Out", "Quad", 0.15, true)
            G2L_button.BackgroundTransparency = 0
            G2L_button.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        end)

        G2L_button.MouseButton1Click:Connect(function()
            ClickSound(G2L_button)
            V3()
        end)
       Tab[V2] = G2L_button
       return G2L_button
    end

    function Tab:AddButton(buttonName, callback)
        return Tab:CreateButton({Name = buttonName, Callback = callback})
    end

    function Tab:DestroyButton(buttonName)
        local btn = Tab[buttonName]
        if btn then
            btn:Destroy()
            Tab[buttonName] = nil
        end
    end

    function Tab:Toggle(V1)
        local V2 = V1.Title or V1.Name or "Toggle"
        local V3 = V1.Callback or function() end
        local V4 = V1.Default or false
        Tab._toggles = Tab._toggles or {}
        local saved = UiLib.CONFIG[V2]
        local state = saved ~= nil and saved or V4 or false
        local G2L_toggle = Instance.new("TextButton", G2L_tabFrame)
        G2L_toggle.Text = ""
        G2L_toggle.BorderSizePixel = 0
        G2L_toggle.BackgroundTransparency = 0
        G2L_toggle.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        G2L_toggle.Size = UDim2.new(0.98, 0, 0, 36)
        G2L_toggle.AutoButtonColor = false
        Instance.new("UICorner", G2L_toggle).CornerRadius = UDim.new(0, 6)
        local G2L_label = Instance.new("TextLabel", G2L_toggle)
        G2L_label.Text = V2
        G2L_label.TextSize = 18
        G2L_label.TextWrapped = true
        G2L_label.TextStrokeTransparency = 0.2
        G2L_label.BorderSizePixel = 0
        G2L_label.BackgroundTransparency = 1
        G2L_label.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        G2L_label.TextColor3 = Color3.fromRGB(255, 255, 255)
        G2L_label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        G2L_label.FontFace = fontFaceRegular
        G2L_label.Size = UDim2.new(1, -50, 1, 0)
        G2L_label.Position = UDim2.new(0, 10, 0, 0)
        G2L_label.TextXAlignment = Enum.TextXAlignment.Center
        local G2L_toggleBack = Instance.new("Frame", G2L_toggle)
        G2L_toggleBack.Size = UDim2.new(0, 40, 0, 24)
        G2L_toggleBack.Position = UDim2.new(1, -50, 0.5, -12)
        G2L_toggleBack.BackgroundColor3 = state and Color3.fromRGB(0, 170, 127) or Color3.fromRGB(100, 100, 100)
        G2L_toggleBack.BorderSizePixel = 0
        Instance.new("UICorner", G2L_toggleBack).CornerRadius = UDim.new(1, 0)
        local G2L_circle = Instance.new("Frame", G2L_toggleBack)
        G2L_circle.Size = UDim2.new(0, 20, 0, 20)
        G2L_circle.Position = UDim2.new(state and 1 or 0, state and -22 or 2, 0.5, -10)
        G2L_circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        G2L_circle.BorderSizePixel = 0
        Instance.new("UICorner", G2L_circle).CornerRadius = UDim.new(1, 0)
        G2L_toggle.MouseEnter:Connect(function()
            G2L_toggle.BackgroundTransparency = 0
            G2L_toggle.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        end)
        G2L_toggle.MouseLeave:Connect(function()
            G2L_toggle.BackgroundTransparency = 0
            G2L_toggle.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        end)
        local toggle = {}
        toggle.Name = V2
        toggle.SetState = function(newState)
            state = newState
            UiLib.CONFIG[V2] = state
            G2L_toggleBack.BackgroundColor3 = state and Color3.fromRGB(0, 170, 127) or Color3.fromRGB(100, 100, 100)
            G2L_circle:TweenPosition(UDim2.new(state and 1 or 0, state and -22 or 2, 0.5, -10), "Out", "Quad", 0.2, true)
            V3(state)
        end
        G2L_toggle.MouseButton1Click:Connect(function()
            toggle.SetState(not state)
            ClickSound(G2L_toggle)
        end)
        if saved == true then
            task.defer(function()
                V3(state)
            end)
        end
        Tab._toggles = Tab._toggles or {}
        table.insert(Tab._toggles, toggle)
        return toggle
    end

    function Tab:AddToggle(toggleName, defaultState, callback)
        return Tab:Toggle({Title = toggleName, Default = defaultState, Callback = callback})
    end

    return Tab
end

UiLib.CONFIG = {}
UiLib.AUTOLOAD = false
UiLib.DEFAULT_CONFIG = "default.json"

function UiLib:SaveConfig(filename)
    if writefile then
        local data = {
            CONFIG = self.CONFIG,
            AUTOLOAD = self.AUTOLOAD,
            DEFAULT = self.DEFAULT_CONFIG
        }
        writefile(configz .. "/" .. filename, HttpService:JSONEncode(data))
        return filename
    end
end

function UiLib:LoadConfig(filename)
    local decoded = {}
    local success, result = pcall(function()
        return HttpService:JSONDecode(filename or "{}")
    end)
    if success and type(result) == "table" then
        decoded = result
    else
        if readfile and isfile and type(filename) == "string" then
            local path = configz .. "/" .. filename
            if isfile(path) then
                local fileSuccess, fileResult = pcall(function()
                    return HttpService:JSONDecode(readfile(path))
                end)
                if fileSuccess and type(fileResult) == "table" then
                    decoded = fileResult
                end
            end
        end
    end
    decoded = decoded or {}
    self.CONFIG = decoded.CONFIG or {}
    self.AUTOLOAD = decoded.AUTOLOAD or false
    self.DEFAULT_CONFIG = decoded.DEFAULT or self.DEFAULT_CONFIG
    for _, tab in pairs(self._tabs or {}) do
        for _, toggle in ipairs(tab._toggles or {}) do
            if toggle.Name and self.CONFIG[toggle.Name] ~= nil then
                toggle.SetState(self.CONFIG[toggle.Name])
            end
        end
    end
end

return UiLib
