function UiLib:KeySystem()
    if UiLib.KEY_VALID then
        return true
    end

    local function verifyKey(key)
        local response = request({
            Url = "https://peeky.pythonanywhere.com/use_key",
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/x-www-form-urlencoded",
                ["X-HWID"] = gethwid()
            },
            Body = "key=" .. key
        })

        if not response then
            return false
        end

        local body = response.Body
        if body == "KEY_VALID" or body == "KEY_BOUND_SUCCESS" then
            return true
        end
        return false
    end

    if readfile and isfile(keyFile) then
        if verifyKey(readfile(keyFile)) then
            UiLib.KEY_VALID = true
            return true
        end
    end

